{
  "name": "mgv-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack -H 127.0.0.1 -p 3000",
    "build": "next build --webpack",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:bootstrap": "node --import tsx prisma/bootstrap.ts",
    "db:studio": "prisma studio",
    "render:build": "prisma generate && prisma migrate deploy && next build --webpack"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "lucide-react": "^0.468.0",
    "next": "16.2.9",
    "pg": "^8.13.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.9",
    "prisma": "7.8.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=22"
  }
}
